# Copiá este archivo: cp .env.example .env

NODE_ENV=development
PORT=3000

# Postgres (Neon) — usá la URL del pooler (host con -pooler)
DATABASE_URL=postgresql://neondb_owner:npg_dk9FxpfwuH1L@ep-shy-flower-ajv7wkz9-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Mínimo 32 caracteres — generá uno con: openssl rand -base64 64
